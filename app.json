{
  "expo": {
    "name": "EasyCollect",
    "slug": "easycollect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "easycollect",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3b82f6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easycollect.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3b82f6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.easycollect.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EasyCollect to access your photos to upload payment proofs.",
          "cameraPermission": "Allow EasyCollect to use your camera to take photos of payment proofs."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "583f4db7-3c3a-4f60-b2b4-a5de5f1dc040"
      }
    }
  }
}
